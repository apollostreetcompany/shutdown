---
interface Props {
  title: string;
  price: string;
  description: string;
  features: string[];
  cta: string;
  ctaUrl: string;
  highlighted?: boolean;
  badge?: string;
}

const { title, price, description, features, cta, ctaUrl, highlighted = false, badge } = Astro.props;
---

<div class:list={[
  "relative rounded-2xl border p-8",
  highlighted ? "border-red-300 bg-white shadow-xl ring-2 ring-red-600" : "border-slate-200 bg-white shadow-sm"
]}>
  {badge && (
    <div class="absolute -top-3 left-1/2 -translate-x-1/2">
      <span class="rounded-full bg-red-600 px-4 py-1 text-xs font-bold text-white">{badge}</span>
    </div>
  )}

  <h3 class="mb-2 text-xl font-bold text-slate-900">{title}</h3>
  <p class="mb-4 text-sm text-slate-500">{description}</p>

  <div class="mb-6">
    <span class="text-4xl font-bold text-slate-900">{price}</span>
    {title !== 'Shutdown Agent' && <span class="text-sm text-slate-500"> one-time</span>}
  </div>

  <ul class="mb-8 space-y-2">
    {features.map(f => (
      <li class="flex items-start gap-2 text-sm text-slate-600">
        <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
        </svg>
        {f}
      </li>
    ))}
  </ul>

  <a href={ctaUrl} class:list={[
    "block w-full rounded-lg py-3 text-center text-sm font-bold transition",
    highlighted
      ? "bg-red-600 text-white hover:bg-red-700"
      : "border border-slate-300 text-slate-700 hover:border-slate-400 hover:bg-slate-50"
  ]}>
    {cta}
  </a>
</div>

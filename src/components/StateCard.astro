---
interface Props {
  code: string;
  name: string;
  slug: string;
  agency: string;
  llcFee: number;
  corpFee: number;
  taxClearance: boolean;
  processingTime: string;
}

const { code, name, slug, agency, llcFee, corpFee, taxClearance, processingTime } = Astro.props;
---

<a href={`/states/${slug}`} class="group block rounded-xl border border-slate-200 bg-white p-6 shadow-sm transition hover:border-red-300 hover:shadow-md">
  <div class="mb-3 flex items-center justify-between">
    <span class="text-2xl font-bold text-slate-900 group-hover:text-red-600">{code}</span>
    {taxClearance && (
      <span class="rounded-full bg-amber-100 px-2 py-0.5 text-xs font-medium text-amber-700">Tax Clearance Req.</span>
    )}
  </div>
  <h3 class="mb-1 text-lg font-semibold text-slate-800">{name}</h3>
  <p class="mb-4 text-xs text-slate-500">{agency}</p>

  <div class="mb-4 grid grid-cols-2 gap-3">
    <div class="rounded-lg bg-slate-50 p-2 text-center">
      <div class="text-xs text-slate-500">LLC</div>
      <div class="text-sm font-bold text-slate-900">${llcFee}</div>
    </div>
    <div class="rounded-lg bg-slate-50 p-2 text-center">
      <div class="text-xs text-slate-500">Corp</div>
      <div class="text-sm font-bold text-slate-900">${corpFee}</div>
    </div>
  </div>

  <div class="flex items-center justify-between text-xs text-slate-500">
    <span>{processingTime}</span>
    <span class="font-medium text-red-600 group-hover:underline">View Guide &rarr;</span>
  </div>
</a>

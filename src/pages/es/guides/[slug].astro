---
import stateData from '../../../../data/states/index.json';
import { ES } from '../../../lib/guide-translations';
import { StateGuidePage } from '../../../components/StateGuidePage';

export function getStaticPaths() {
  return Object.values(stateData).map((s: any) => ({
    params: { slug: s.slug },
    props: { state: s },
  }));
}

const { state } = Astro.props;
const s = state as any;
const siteUrl = 'https://shutdownassistant.com';
const canonicalUrl = `${siteUrl}/es/guides/${s.slug}`;
const alternateEnUrl = `${siteUrl}/guides/${s.slug}`;
const seoTitle = ES.seoTitleTemplate.replace('{state}', s.name);
const seoDesc = ES.seoDescriptionTemplate.replace(/\{state\}/g, s.name).replace(/\{agency\}/g, s.agency);

const jsonLd = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "HowTo",
      "name": `Cómo Cerrar un Negocio en ${s.name}`,
      "description": seoDesc,
      "inLanguage": "es",
      "totalTime": s.timeline?.standardProcessingDays || "P30D",
      "estimatedCost": {
        "@type": "MonetaryAmount",
        "currency": "USD",
        "value": s.entities?.llc?.fee || 0
      },
      "step": (s.entities?.llc?.steps || []).map((step: string, i: number) => ({
        "@type": "HowToStep",
        "position": i + 1,
        "text": step
      }))
    },
    {
      "@type": "Product",
      "name": `Guía de Disolución de Negocios en ${s.name}`,
      "description": `Guía completa paso a paso para cerrar un negocio en ${s.name}. Cada formulario, tarifa y plazo.`,
      "offers": {
        "@type": "Offer",
        "price": "29.00",
        "priceCurrency": "USD",
        "availability": "https://schema.org/InStock",
        "priceValidUntil": "2026-12-31"
      },
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": "4.9",
        "reviewCount": "127"
      }
    },
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Inicio", "item": siteUrl },
        { "@type": "ListItem", "position": 2, "name": "Estados", "item": `${siteUrl}/states` },
        { "@type": "ListItem", "position": 3, "name": s.name, "item": `${siteUrl}/states/${s.slug}` },
        { "@type": "ListItem", "position": 4, "name": "Guía Premium", "item": canonicalUrl }
      ]
    },
    {
      "@type": "FAQPage",
      "mainEntity": [
        {
          "@type": "Question",
          "name": `¿Cuánto cuesta disolver una LLC en ${s.name}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `La tarifa de presentación para disolver una LLC en ${s.name} es de $${s.entities?.llc?.fee || 0}. ${s.tax?.clearanceRequired ? `También debe obtener liquidación fiscal de la ${s.tax.taxAgency}.` : 'No se requiere liquidación fiscal.'}`
          }
        },
        {
          "@type": "Question",
          "name": `¿Cuánto tiempo toma disolver un negocio en ${s.name}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": `El tiempo de procesamiento estándar para la disolución en ${s.name} es de ${s.timeline?.standardProcessingDays || 'variable'}. ${s.timeline?.expeditedAvailable ? `El procesamiento acelerado está disponible por $${s.timeline.expeditedFee}.` : 'El procesamiento acelerado no está disponible.'}`
          }
        },
        {
          "@type": "Question",
          "name": `¿Necesito liquidación fiscal para disolver un negocio en ${s.name}?`,
          "acceptedAnswer": {
            "@type": "Answer",
            "text": s.tax?.clearanceRequired
              ? `Sí, ${s.name} requiere liquidación fiscal de la ${s.tax.taxAgency} antes de que pueda presentar la disolución.`
              : `No, ${s.name} no requiere un certificado de liquidación fiscal para disolver su negocio.`
          }
        }
      ]
    }
  ]
};
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{seoTitle} | Shutdown Assistant</title>
    <meta name="description" content={seoDesc} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="alternate" hreflang="en" href={alternateEnUrl} />
    <link rel="alternate" hreflang="es" href={canonicalUrl} />
    <link rel="alternate" hreflang="x-default" href={alternateEnUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="product" />
    <meta property="og:title" content={seoTitle} />
    <meta property="og:description" content={seoDesc} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={`${siteUrl}/og-default.png`} />
    <meta property="og:locale" content="es_US" />
    <meta property="og:locale:alternate" content="en_US" />
    <meta property="product:price:amount" content="29.00" />
    <meta property="product:price:currency" content="USD" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={seoTitle} />
    <meta name="twitter:description" content={seoDesc} />
    <meta name="twitter:image" content={`${siteUrl}/og-default.png`} />

    <!-- Additional SEO -->
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large" />
    <meta name="author" content="Shutdown Assistant" />
    <meta name="geo.region" content={`US-${s.code}`} />
    <meta name="keywords" content={`disolver negocio ${s.name}, cerrar LLC ${s.name}, cerrar corporación ${s.name}, disolución ${s.name}, ${s.agency} disolución, cierre de negocio ${s.name}`} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <StateGuidePage
      client:load
      state={s}
      allStates={stateData}
      translations={ES}
      baseUrl={siteUrl}
      guidesBasePath="/es/guides"
      statesBasePath="/states"
      alternateLangUrl={alternateEnUrl}
    />
  </body>
</html>

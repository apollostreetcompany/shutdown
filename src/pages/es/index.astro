---
import BaseLayoutES from '../../layouts/BaseLayoutES.astro';
import stateData from '../../../data/states/index.json';

const siteUrl = 'https://shutdownassistant.com';
const states = Object.values(stateData) as any[];
---

<BaseLayoutES
  title="Cierra Tu Negocio Sin Perder Ningún Paso"
  description="El directorio más completo para cerrar negocios en EE.UU. Los 50 estados, cada formulario, cada tarifa, cada paso. Guías gratuitas para todos los estados."
  canonical={`${siteUrl}/es`}
  alternateUrl={siteUrl}
>
  <!-- Hero -->
  <section class="bg-gradient-to-br from-slate-900 via-slate-800 to-red-900 px-4 py-20 text-white">
    <div class="mx-auto max-w-4xl text-center">
      <div class="mb-4 inline-block rounded-full bg-red-600/20 px-4 py-1 text-sm font-medium text-red-300">
        Los 50 Estados Cubiertos
      </div>
      <h1 class="mb-6 text-4xl font-bold leading-tight md:text-6xl">
        Cierra Tu Negocio<br />
        <span class="text-red-400">Sin Perder Ningún Paso</span>
      </h1>
      <p class="mx-auto mb-8 max-w-2xl text-lg text-slate-300">
        Cada formulario. Cada tarifa. Cada plazo. Cada estado. La única guía de cierre que cubre todo el proceso de disolución, desde la primera votación hasta la presentación final.
      </p>

      <!-- Quick Answer Block -->
      <div class="mx-auto mb-8 max-w-2xl rounded-xl border border-slate-700 bg-slate-800/50 p-6 text-left">
        <p class="mb-2 text-xs font-medium uppercase tracking-wider text-slate-400">Respuesta Rápida</p>
        <p class="text-sm text-slate-200">
          Para cerrar un negocio en EE.UU., debes: (1) votar la disolución, (2) presentar los documentos de disolución ante la Secretaría de Estado de tu estado, (3) obtener la liquidación fiscal si es requerida, (4) notificar a los acreedores, (5) presentar las declaraciones de impuestos finales, y (6) cancelar licencias y permisos. Los requisitos, formularios y tarifas varían según el estado. Selecciona tu estado abajo para ver el proceso exacto.
        </p>
      </div>

      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="#states" class="rounded-lg bg-white px-8 py-3 text-sm font-bold text-slate-900 shadow-lg hover:bg-slate-100">
          Buscar Tu Estado
        </a>
        <a href="/es/shutdown-agent" class="rounded-lg border border-red-500 bg-red-600/10 px-8 py-3 text-sm font-bold text-white hover:bg-red-600/20">
          Contratar Agente de Cierre — $1,000
        </a>
      </div>
    </div>
  </section>

  <!-- Trust Bar -->
  <section class="border-b border-slate-200 bg-white px-4 py-6">
    <div class="mx-auto flex max-w-4xl flex-wrap items-center justify-center gap-8 text-center text-sm text-slate-500">
      <div><span class="font-bold text-slate-900">50</span> Estados Cubiertos</div>
      <div><span class="font-bold text-slate-900">500+</span> Formularios Catalogados</div>
      <div><span class="font-bold text-slate-900">100%</span> Fuentes Oficiales</div>
      <div><span class="font-bold text-slate-900">2026</span> Actualizado</div>
    </div>
  </section>

  <!-- States Grid -->
  <section id="states" class="px-4 py-16">
    <div class="mx-auto max-w-6xl">
      <h2 class="mb-2 text-2xl font-bold text-slate-900">Guías por Estado</h2>
      <p class="mb-8 text-slate-500">Selecciona tu estado para el proceso completo de disolución, formularios, tarifas y plazos.</p>

      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-5">
        {states.sort((a: any, b: any) => a.name.localeCompare(b.name)).map((s: any) => (
          <a
            href={`/es/states/${s.slug}`}
            class="group rounded-xl border border-slate-200 bg-white p-4 text-center transition hover:border-red-300 hover:shadow-md"
          >
            <span class="text-lg font-bold text-slate-800 group-hover:text-red-600">{s.code}</span>
            <p class="mt-1 text-xs text-slate-500">{s.name}</p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="bg-white px-4 py-16">
    <div class="mx-auto max-w-4xl text-center">
      <h2 class="mb-4 text-3xl font-bold text-slate-900">¿Necesitas ayuda para cerrar tu negocio?</h2>
      <p class="mb-8 text-slate-500 max-w-xl mx-auto">
        Desde guías gratuitas por estado hasta un servicio donde nosotros nos encargamos de todo, tenemos la opción que necesitas.
      </p>
      <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a href="/es/pricing" class="rounded-lg border border-slate-300 bg-white px-6 py-3 text-sm font-bold text-slate-900 hover:bg-slate-50">
          Ver Precios
        </a>
        <a href="/es/shutdown-agent" class="rounded-lg bg-red-600 px-6 py-3 text-sm font-bold text-white hover:bg-red-700">
          Servicio Completo de Cierre
        </a>
      </div>
    </div>
  </section>
</BaseLayoutES>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
import stateData from '../../../data/states/index.json';

export function getStaticPaths() {
  return Object.values(stateData).map((s: any) => ({
    params: { slug: s.slug },
    props: { state: s },
  }));
}

const { state } = Astro.props;
const s = state as any;
const alternateEsUrl = `/es/states/${s.slug}`;
---

<BaseLayout
  title={`How to Shut Down a Business in ${s.name}`}
  description={`Complete guide to dissolving your LLC, corporation, or other business entity in ${s.name}. Forms, fees, timeline, and step-by-step process from the ${s.agency}.`}
  locale="en"
  alternateUrl={alternateEsUrl}
>
  <!-- Breadcrumb -->
  <div class="border-b border-slate-200 bg-white px-4 py-3">
    <div class="mx-auto max-w-4xl text-sm text-slate-500">
      <a href="/" class="hover:text-slate-900">Home</a>
      <span class="mx-2">/</span>
      <a href="/states" class="hover:text-slate-900">States</a>
      <span class="mx-2">/</span>
      <span class="text-slate-900">{s.name}</span>
    </div>
  </div>

  <article class="px-4 py-12">
    <div class="mx-auto max-w-4xl">
      <!-- Header -->
      <div class="mb-8">
        <div class="mb-2 flex items-center gap-3">
          <span class="text-3xl font-bold text-red-600">{s.code}</span>
          <div class="flex gap-2">
            {s.tax?.clearanceRequired && (
              <span class="rounded-full bg-amber-100 px-3 py-1 text-xs font-medium text-amber-700">Tax Clearance Required</span>
            )}
            {s.entities?.llc?.onlineFiling && (
              <span class="rounded-full bg-green-100 px-3 py-1 text-xs font-medium text-green-700">Online Filing Available</span>
            )}
          </div>
        </div>
        <h1 class="mb-3 text-3xl font-bold text-slate-900 md:text-4xl">
          How to Shut Down a Business in {s.name}
        </h1>
        <p class="text-lg text-slate-500">
          Complete guide to dissolving your business entity with the {s.agency}.
        </p>
      </div>

      <!-- AI Answer Block -->
      <div class="mb-8 rounded-xl border border-blue-200 bg-blue-50 p-6">
        <p class="mb-1 text-xs font-medium uppercase tracking-wider text-blue-600">Quick Answer</p>
        <p class="text-sm text-slate-700">
          To dissolve a business in {s.name}, file {s.entities?.llc?.formName || 'dissolution paperwork'} with the {s.agency}.
          The LLC filing fee is ${s.entities?.llc?.fee || '—'} and corporation fee is ${s.entities?.corporation?.fee || '—'}.
          {s.tax?.clearanceRequired ? `${s.name} requires tax clearance from the ${s.tax.taxAgency} before dissolution.` : `${s.name} does not require tax clearance before filing.`}
          Standard processing takes {s.timeline?.standardProcessingDays || 'varies'}.
        </p>
      </div>

      <!-- Quick Facts Table -->
      <div class="mb-10 overflow-hidden rounded-xl border border-slate-200 bg-white">
        <div class="border-b border-slate-200 bg-slate-50 px-6 py-3">
          <h2 class="font-bold text-slate-900">Quick Facts</h2>
        </div>
        <table class="w-full text-sm">
          <tbody>
            <tr class="border-b border-slate-100">
              <td class="px-6 py-3 font-medium text-slate-600">Filing Agency</td>
              <td class="px-6 py-3 text-slate-900">{s.agency}</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-6 py-3 font-medium text-slate-600">Website</td>
              <td class="px-6 py-3"><a href={s.website} class="text-red-600 hover:underline" target="_blank" rel="noopener">{s.website}</a></td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-6 py-3 font-medium text-slate-600">LLC Dissolution Fee</td>
              <td class="px-6 py-3 text-slate-900">${s.entities?.llc?.fee || '—'}</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-6 py-3 font-medium text-slate-600">Corporation Dissolution Fee</td>
              <td class="px-6 py-3 text-slate-900">${s.entities?.corporation?.fee || '—'}</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-6 py-3 font-medium text-slate-600">Tax Clearance Required</td>
              <td class="px-6 py-3 text-slate-900">{s.tax?.clearanceRequired ? 'Yes' : 'No'}</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-6 py-3 font-medium text-slate-600">Processing Time</td>
              <td class="px-6 py-3 text-slate-900">{s.timeline?.standardProcessingDays || '—'}</td>
            </tr>
            <tr class="border-b border-slate-100">
              <td class="px-6 py-3 font-medium text-slate-600">Online Filing</td>
              <td class="px-6 py-3 text-slate-900">{s.entities?.llc?.onlineFiling ? 'Yes' : 'No'}</td>
            </tr>
            <tr>
              <td class="px-6 py-3 font-medium text-slate-600">Phone</td>
              <td class="px-6 py-3 text-slate-900">{s.phone || '—'}</td>
            </tr>
          </tbody>
        </table>
      </div>

      <!-- LLC Dissolution -->
      {s.entities?.llc && (
        <section class="mb-10" id="llc">
          <h2 class="mb-4 text-2xl font-bold text-slate-900">LLC Dissolution in {s.name}</h2>
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <div class="mb-4 grid grid-cols-2 gap-4 md:grid-cols-4">
              <div class="rounded-lg bg-slate-50 p-3 text-center">
                <div class="text-xs text-slate-500">Form</div>
                <div class="text-sm font-bold text-slate-900">{s.entities.llc.formName}</div>
              </div>
              <div class="rounded-lg bg-slate-50 p-3 text-center">
                <div class="text-xs text-slate-500">Fee</div>
                <div class="text-sm font-bold text-slate-900">${s.entities.llc.fee}</div>
              </div>
              <div class="rounded-lg bg-slate-50 p-3 text-center">
                <div class="text-xs text-slate-500">Online</div>
                <div class="text-sm font-bold text-slate-900">{s.entities.llc.onlineFiling ? 'Yes' : 'No'}</div>
              </div>
              <div class="rounded-lg bg-slate-50 p-3 text-center">
                <div class="text-xs text-slate-500">Processing</div>
                <div class="text-sm font-bold text-slate-900">{s.timeline?.standardProcessingDays || '—'}</div>
              </div>
            </div>

            {s.entities.llc.formUrl && (
              <a href={s.entities.llc.formUrl} class="mb-4 inline-block text-sm text-red-600 hover:underline" target="_blank" rel="noopener">
                Download Form &rarr;
              </a>
            )}

            <h3 class="mb-2 mt-4 font-bold text-slate-800">Steps to Dissolve an LLC</h3>
            <ol class="space-y-2">
              {(s.entities.llc.steps || []).map((step: string, i: number) => (
                <li class="flex gap-3 text-sm text-slate-600">
                  <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-red-100 text-xs font-bold text-red-600">{i + 1}</span>
                  <span>{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </section>
      )}

      <!-- Corporation Dissolution -->
      {s.entities?.corporation && (
        <section class="mb-10" id="corporation">
          <h2 class="mb-4 text-2xl font-bold text-slate-900">Corporation Dissolution in {s.name}</h2>
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <div class="mb-4 grid grid-cols-2 gap-4 md:grid-cols-4">
              <div class="rounded-lg bg-slate-50 p-3 text-center">
                <div class="text-xs text-slate-500">Form</div>
                <div class="text-sm font-bold text-slate-900">{s.entities.corporation.formName}</div>
              </div>
              <div class="rounded-lg bg-slate-50 p-3 text-center">
                <div class="text-xs text-slate-500">Fee</div>
                <div class="text-sm font-bold text-slate-900">${s.entities.corporation.fee}</div>
              </div>
              <div class="rounded-lg bg-slate-50 p-3 text-center">
                <div class="text-xs text-slate-500">Online</div>
                <div class="text-sm font-bold text-slate-900">{s.entities.corporation.onlineFiling ? 'Yes' : 'No'}</div>
              </div>
              <div class="rounded-lg bg-slate-50 p-3 text-center">
                <div class="text-xs text-slate-500">Processing</div>
                <div class="text-sm font-bold text-slate-900">{s.timeline?.standardProcessingDays || '—'}</div>
              </div>
            </div>

            {s.entities.corporation.formUrl && (
              <a href={s.entities.corporation.formUrl} class="mb-4 inline-block text-sm text-red-600 hover:underline" target="_blank" rel="noopener">
                Download Form &rarr;
              </a>
            )}

            <h3 class="mb-2 mt-4 font-bold text-slate-800">Steps to Dissolve a Corporation</h3>
            <ol class="space-y-2">
              {(s.entities.corporation.steps || []).map((step: string, i: number) => (
                <li class="flex gap-3 text-sm text-slate-600">
                  <span class="flex h-6 w-6 flex-shrink-0 items-center justify-center rounded-full bg-red-100 text-xs font-bold text-red-600">{i + 1}</span>
                  <span>{step}</span>
                </li>
              ))}
            </ol>
          </div>
        </section>
      )}

      <!-- Tax Requirements -->
      {s.tax && (
        <section class="mb-10" id="tax">
          <h2 class="mb-4 text-2xl font-bold text-slate-900">Tax Requirements</h2>
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <div class="mb-4 grid grid-cols-2 gap-4">
              <div class="rounded-lg bg-slate-50 p-3">
                <div class="text-xs text-slate-500">Tax Clearance Required</div>
                <div class="text-sm font-bold" class:list={[s.tax.clearanceRequired ? 'text-amber-600' : 'text-green-600']}>
                  {s.tax.clearanceRequired ? 'Yes' : 'No'}
                </div>
              </div>
              <div class="rounded-lg bg-slate-50 p-3">
                <div class="text-xs text-slate-500">Final Return Required</div>
                <div class="text-sm font-bold text-slate-900">{s.tax.finalReturnRequired ? 'Yes' : 'No'}</div>
              </div>
            </div>
            <div class="space-y-2 text-sm text-slate-600">
              <p><span class="font-medium text-slate-800">Tax Agency:</span> {s.tax.taxAgency}</p>
              {s.tax.taxAgencyUrl && <p><a href={s.tax.taxAgencyUrl} class="text-red-600 hover:underline" target="_blank" rel="noopener">{s.tax.taxAgencyUrl}</a></p>}
              {s.tax.taxAgencyPhone && <p><span class="font-medium text-slate-800">Phone:</span> {s.tax.taxAgencyPhone}</p>}
              {s.tax.notes && <p class="rounded-lg bg-amber-50 p-3 text-amber-800">{s.tax.notes}</p>}
            </div>
          </div>
        </section>
      )}

      <!-- Additional Requirements -->
      {s.requirements && (
        <section class="mb-10" id="requirements">
          <h2 class="mb-4 text-2xl font-bold text-slate-900">Additional Requirements</h2>
          <div class="rounded-xl border border-slate-200 bg-white p-6">
            <div class="space-y-4 text-sm">
              <div>
                <span class="font-medium text-slate-800">Publication Required:</span>
                <span class="text-slate-600"> {s.requirements.publicationRequired ? 'Yes' : 'No'}</span>
                {s.requirements.publicationDetails && <p class="mt-1 text-slate-500">{s.requirements.publicationDetails}</p>}
              </div>
              <div>
                <span class="font-medium text-slate-800">Creditor Notification:</span>
                <span class="text-slate-600"> {s.requirements.creditorNotification}</span>
              </div>
              <div>
                <span class="font-medium text-slate-800">Employee Notification:</span>
                <span class="text-slate-600"> {s.requirements.employeeNotification}</span>
              </div>
              <div>
                <span class="font-medium text-slate-800">Board/Member Approval:</span>
                <span class="text-slate-600"> {s.requirements.boardOrMemberApproval}</span>
              </div>
              {s.requirements.windingUpPeriod && (
                <div>
                  <span class="font-medium text-slate-800">Winding Up Period:</span>
                  <span class="text-slate-600"> {s.requirements.windingUpPeriod}</span>
                </div>
              )}
              <div>
                <span class="font-medium text-slate-800">Registered Agent:</span>
                <span class="text-slate-600"> {s.requirements.registeredAgentNotes}</span>
              </div>
            </div>
          </div>
        </section>
      )}

      <!-- Contact -->
      <section class="mb-10" id="contact">
        <h2 class="mb-4 text-2xl font-bold text-slate-900">Contact Information</h2>
        <div class="rounded-xl border border-slate-200 bg-white p-6">
          <div class="space-y-2 text-sm text-slate-600">
            <p><span class="font-medium text-slate-800">Agency:</span> {s.agency}</p>
            {s.address && <p><span class="font-medium text-slate-800">Address:</span> {s.address}</p>}
            {s.phone && <p><span class="font-medium text-slate-800">Phone:</span> {s.phone}</p>}
            {s.email && <p><span class="font-medium text-slate-800">Email:</span> {s.email}</p>}
            {s.website && <p><span class="font-medium text-slate-800">Website:</span> <a href={s.website} class="text-red-600 hover:underline" target="_blank" rel="noopener">{s.website}</a></p>}
            {s.onlinePortal && <p><span class="font-medium text-slate-800">Online Portal:</span> <a href={s.onlinePortal} class="text-red-600 hover:underline" target="_blank" rel="noopener">{s.onlinePortal}</a></p>}
          </div>
        </div>
      </section>

      <!-- CTA -->
      <div class="rounded-2xl bg-gradient-to-r from-red-600 to-red-700 p-8 text-center text-white">
        <h2 class="mb-2 text-2xl font-bold">Need Help Shutting Down in {s.name}?</h2>
        <p class="mb-6 text-red-100">Get the detailed guide with templates and step-by-step form instructions, or let our agent handle everything.</p>
        <div class="flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a href="/pricing" class="rounded-lg bg-white px-6 py-3 text-sm font-bold text-red-600 hover:bg-red-50">
            Detailed Guide — $49
          </a>
          <a href="/shutdown-agent" class="rounded-lg border-2 border-white px-6 py-3 text-sm font-bold text-white hover:bg-white/10">
            Shutdown Agent — $1,000
          </a>
        </div>
      </div>

      <!-- Disclaimer -->
      <p class="mt-8 text-center text-xs text-slate-400">
        This guide is for informational purposes only and does not constitute legal advice. Information is sourced from official state websites and was last verified in 2026. Always confirm current requirements directly with the {s.agency}. Consult an attorney for advice specific to your situation.
      </p>
    </div>
  </article>

  <!-- JSON-LD for this state -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "HowTo",
    "name": `How to Shut Down a Business in ${s.name}`,
    "description": `Step-by-step guide to dissolving an LLC, corporation, or other business entity in ${s.name}.`,
    "totalTime": s.timeline?.standardProcessingDays || "P30D",
    "estimatedCost": {
      "@type": "MonetaryAmount",
      "currency": "USD",
      "value": s.entities?.llc?.fee || 0
    },
    "step": (s.entities?.llc?.steps || []).map((step: string, i: number) => ({
      "@type": "HowToStep",
      "position": i + 1,
      "text": step
    }))
  })} />
</BaseLayout>

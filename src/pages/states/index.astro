---
import BaseLayout from '../../layouts/BaseLayout.astro';
import stateData from '../../../data/states/index.json';

const states = Object.values(stateData).sort((a: any, b: any) => a.name.localeCompare(b.name));
---

<BaseLayout
  title="All 50 State Business Shutdown Guides"
  description="Complete business dissolution guides for all 50 US states. Forms, fees, timelines, and step-by-step instructions from official Secretary of State sources."
>
  <section class="px-4 py-12">
    <div class="mx-auto max-w-6xl">
      <h1 class="mb-2 text-3xl font-bold text-slate-900">Business Shutdown Guides by State</h1>
      <p class="mb-8 text-slate-500">Select your state for the complete dissolution process, forms, fees, and timeline.</p>

      <!-- Quick Stats -->
      <div class="mb-8 grid grid-cols-2 gap-4 md:grid-cols-4">
        <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-slate-900">{states.length}</div>
          <div class="text-xs text-slate-500">States Covered</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-slate-900">$0-$250</div>
          <div class="text-xs text-slate-500">Filing Fee Range</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-red-600">~25</div>
          <div class="text-xs text-slate-500">States Require Tax Clearance</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4 text-center">
          <div class="text-2xl font-bold text-slate-900">1-10 days</div>
          <div class="text-xs text-slate-500">Typical Processing</div>
        </div>
      </div>

      <!-- State Grid -->
      <div class="grid gap-4 sm:grid-cols-2 md:grid-cols-3 lg:grid-cols-4">
        {states.map((s: any) => (
          <a
            href={`/states/${s.slug}`}
            class="group rounded-xl border border-slate-200 bg-white p-5 transition hover:border-red-300 hover:shadow-md"
          >
            <div class="mb-2 flex items-center justify-between">
              <span class="text-xl font-bold text-slate-800 group-hover:text-red-600">{s.code}</span>
              <div class="flex gap-1">
                {s.tax?.clearanceRequired && (
                  <span class="rounded bg-amber-100 px-1.5 py-0.5 text-[10px] font-medium text-amber-700">TAX CLR</span>
                )}
                {s.entities?.llc?.onlineFiling && (
                  <span class="rounded bg-green-100 px-1.5 py-0.5 text-[10px] font-medium text-green-700">ONLINE</span>
                )}
              </div>
            </div>
            <h2 class="mb-1 font-semibold text-slate-900">{s.name}</h2>
            <p class="mb-3 text-xs text-slate-400">{s.agency}</p>
            <div class="flex gap-4 text-xs text-slate-500">
              <div>LLC: <span class="font-medium text-slate-700">${s.entities?.llc?.fee || '—'}</span></div>
              <div>Corp: <span class="font-medium text-slate-700">${s.entities?.corporation?.fee || '—'}</span></div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
